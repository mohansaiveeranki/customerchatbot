# Google Gemini API key used for AI-driven persona classification and response generation
GEMINI_API_KEY=YOUR_VALUE_HERE

# OpenAI API key (alternative LLM provider)
OPENAI_API_KEY=YOUR_VALUE_HERE

# Database Connection URL (defaults to SQLite if left blank)
# Example PostgreSQL: postgresql://username:password@localhost:5432/dbname
# Example MySQL: mysql+pymysql://username:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./omnisupport.db

# Force keyword search instead of downloading SentenceTransformers.
# Set to true on memory-constrained environments (like Render free tier).
FORCE_KEYWORD_SEARCH=false

# Host bind address for uvicorn (defaults to 127.0.0.1)
HOST=127.0.0.1

# Port for uvicorn (defaults to 8000)
PORT=8000
